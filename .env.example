# App
NEXT_PUBLIC_APP_URL=http://localhost:3004

# Seed demo (usado por supabase/seed.sql via psql ou criar admin manual)
DEMO_ADMIN_EMAIL=admin@codex.community
DEMO_ADMIN_PASSWORD=codex123!
