# Copie para .env.local e preencha.
# Local: valores gerados por `pnpm db:start`. Cloud: Dashboard Supabase > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Nunca exponha no client. Também usado pelo setup dos testes E2E.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (produção: https://…)
NEXT_PUBLIC_APP_URL=http://localhost:3004

# Sentry — opcional em dev, obrigatório em produção (sem DSN nada é reportado).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis — obrigatório em produção: sem ele o rate-limit vira fallback
# em memória por instância (bypassável em serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Build Docker/Hetzner (output standalone). Deixe de fora na Vercel.
# DOCKER_BUILD=1
